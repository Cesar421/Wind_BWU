# =============================================================================
# API Keys - DO NOT COMMIT THIS FILE
# Copy to .env and fill in your keys
# =============================================================================

# Anthropic Claude API (required)
# Get key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# SerpAPI for Google Scholar (optional but recommended)
# Get key at: https://serpapi.com/
SERPAPI_KEY=your-serpapi-key-here

# MLflow Tracking URI (local by default)
MLFLOW_TRACKING_URI=./mlruns

# Semantic Scholar API Key (optional, increases rate limit)
# Get key at: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# Model for Claude API calls
CLAUDE_MODEL=claude-sonnet-4-20250514
